{
  "name": "chrome-extension-starter",
  "description": "A minimal Chrome Extension starter template — ready to use as a foundation for your next Chrome Extension.",
  "author": "@jirateep12z",
  "license": "MIT",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "node --test tests/lib/format-compact-count.test.ts",
    "lint": "eslint --no-error-on-unmatched-pattern \"src/**/*.{js,ts,jsx,tsx}\" \"public/**/*.js\" \"vite.config.ts\"",
    "lint:fix": "eslint --no-error-on-unmatched-pattern \"src/**/*.{js,ts,jsx,tsx}\" \"public/**/*.js\" \"vite.config.ts\" --fix",
    "format": "prettier --write \"src/**/*.{js,ts,jsx,tsx,json,css,html}\" \"public/**/*.{js,json}\" \"index.html\" \"vite.config.ts\""
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/noto-sans-thai": "^5.2.8",
    "@tailwindcss/vite": "^4.3.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.22.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.1",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^4.12.0",
    "recharts": "^3.9.1",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/chrome": "^0.2.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.9.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.2"
  }
}
